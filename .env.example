# Vu Layer 1 — Environment
# Copy to .env and fill in values. Railway injects these at deploy.

# Postgres (Railway Postgres or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: for local dev without full DB
# DATABASE_URL=postgresql://localhost:5432/vu

# X (Twitter) API — for Phase 1a ingestion (Filtered Stream v2)
X_API_BEARER_TOKEN=
# Optional: comma-separated cashtag symbols, e.g. SOL,BTC,ETH
# CASHTAG_RULES=SOL,BTC,ETH

# Price / asset resolution (Phase 1b, 1c)
# COINGECKO_API_KEY=
# BIRDEYE_API_KEY=

# NLP sentiment (Phase 1e)
# OPENAI_API_KEY=
